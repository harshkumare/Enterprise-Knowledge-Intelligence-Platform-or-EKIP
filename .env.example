# ===========================
# Gemini API Configuration
# ===========================

GOOGLE_API_KEY=your_gemini_api_key_here

# ===========================
# Embedding Model
# ===========================

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ===========================
# FAISS
# ===========================

FAISS_INDEX_PATH=data/faiss_index

# ===========================
# Documents
# ===========================

DOCUMENTS_PATH=docs

# ===========================
# Chunking
# ===========================

CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ===========================
# Retrieval
# ===========================

TOP_K=5